{
  "$schema": "http://json.schemastore.org/template",
  "author": "Black-Moss",
  "classifications": [
    "CUMod",
    "BepInEx",
    "Mod"
  ],
  "identity": "BlackMoss.MossTemplate",
  "name": "Casualties Unknown Mod Template",
  "description": "A template for developing BepInEx mods for Casualties Unknown.",
  "shortName": "mosstemplate",
  "sourceName": "MossTemplate",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "ModDisplayName": {
      "type": "parameter",
      "description": "The display name of your mod (e.g. 'My Cool Mod')",
      "replaces": "Moss Template",
      "defaultValue": "My Mod"
    },
    "ModGuid": {
      "type": "parameter",
      "description": "The unique GUID for your mod (e.g. 'com.example.mymod')",
      "replaces": "org.explosivehydra.mosstemplate",
      "defaultValue": "com.example.mymod"
    },
    "ModVersion": {
      "type": "parameter",
      "description": "The initial version of your mod",
      "replaces": "1.0.0",
      "defaultValue": "1.0.0"
    },
    "AuthorName": {
      "type": "parameter",
      "description": "The author name for LICENSE and project metadata",
      "replaces": "Black-Moss",
      "defaultValue": "Your Name"
    },
    "Description": {
      "type": "parameter",
      "description": "A short description of your mod",
      "replaces": "A mod for Casualties Unknown.",
      "defaultValue": "A mod for Casualties Unknown."
    },
    "GameRootPath": {
      "type": "parameter",
      "description": "Path to the game root directory (e.g. 'E:/SteamLibrary/steamapps/common/Casualties Unknown Demo')",
      "replaces": "__GAME_ROOT_PATH__",
      "defaultValue": "C:/Program Files (x86)/Steam/steamapps/common/Casualties Unknown Demo"
    },
    "ModNamespace": {
      "type": "parameter",
      "description": "Mod namespace for StartGame.ps1 default parameter (same as project name)",
      "replaces": "__MOD_NAMESPACE__",
      "defaultValue": "MyMod"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            ".template.config/**",
            ".git/**",
            ".run/**",
            "obj/**",
            "bin/**",
            "*.DotSettings",
            "*.DotSettings.user",
            "NewMod.ps1"
          ]
        }
      ]
    }
  ]
}
